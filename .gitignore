# --- Claude / agent-local state ----------------------------------------------
.claude/

# --- SAE-LEWIS pipeline outputs ----------------------------------------------
# The smoke pipeline (scripts/smoke_pipeline.sh) defaults to ./runs/, and
# every production-style command in this repo takes its own --out-dir /
# --output-dir / --data-cache-dir. The patterns below cover the common
# choices so a user who follows the README won't accidentally commit
# multi-GB caches or checkpoints.

# All pipeline runs (smoke_pipeline.sh default root, plus a few common
# alternative roots people use locally).
#
# `runs/*` rather than `runs/` on purpose: git does not descend into an
# excluded DIRECTORY, so a nested `!runs/tables/*.md` under `runs/` would be
# silently dead. Excluding the children instead keeps the same protection
# (excluding a directory excludes everything under it) while leaving the
# paper-artifact re-includes at the bottom of this file able to work.
runs/*
outputs/
checkpoints/
models/
artifacts/

# Stage 0: SAE cache + raw Dolma downloads.
dolma_cache/
sae_cache/

# Stage 1: MNTP'd Gemma checkpoints (HF-format dirs).
llm2vec/
llm2vec_out/

# Stage 2: corruption shards + meta.
corruption/
corruption_*/

# Stages 3-5: trained .pt checkpoints (tagger / editor / length head).
tagger/
tagger_out/
editor/
editor_out/
length_head/
length_head_out/

# Loose checkpoint files anywhere (catch users who save to repo root).
*.pt
*.safetensors
*.bin
*.ckpt

# Large binary data artifacts produced by stage 0 / stage 2.
*.npy
*.npz
*.jsonl
*.jsonl.gz
*.json.gz
*.parquet
*.arrow

# meta.json files written by stages 0 / 2 / 3 / 4 / 5. These sit inside the
# ignored run dirs above, but listing the name keeps stray copies out too.
meta.json

# Per-stage logs and timing TSV emitted by the smoke pipeline.
logs/
*.log
timing.tsv

# Hugging Face local cache (set HF_HOME=./hf_cache locally and it lands here).
hf_cache/
.cache/

# --- Project-specific exceptions ---------------------------------------------
# Files we DO want to track despite the patterns above. Order matters: these
# unignores must come after the broader patterns that would otherwise hide
# them.
!requirements.txt
!references.bib
!.gitignore
!scripts/**/*.sh

# --- Paper artifacts: the small text tables, synced miyabi -> local ----------
# Everything the paper is written FROM, and nothing it is not. Order matters
# twice over: these must come after `runs/*` above, and each directory level
# must be re-included BEFORE its contents can be, because git will not look
# inside a directory it has excluded. Verified with `git check-ignore`.
#
# Regenerate rather than hand-edit: every file here is script output
# (run_main_tables.sh / run_frr_rerun.sh / run_judge_checks.sh /
# run_examples.sh), so a re-run legitimately shows up as a diff.

# Top-level notes written straight into runs/.
!runs/*.md

# runs/tables/ — main metrics, per-feature FRR, self-consistency, paired
# McNemar, and the qualitative examples. The .jsonl exception is scoped to
# this directory and currently means only the examples dumps (full
# untruncated texts for quoting); it is NOT a licence for records.jsonl,
# which stays excluded by `runs/prod_gemma_v6/*/*` below.
!runs/tables/
runs/tables/*
!runs/tables/*.md
!runs/tables/*.csv
!runs/tables/*.jsonl

# Per-run report.md from the baselines and sweeps (B1 clamp sweep, B3 steer,
# k-sweep, ...). Their records.jsonl siblings stay ignored.
!runs/prod_gemma_v6/
runs/prod_gemma_v6/*
!runs/prod_gemma_v6/*/
runs/prod_gemma_v6/*/*
!runs/prod_gemma_v6/*/report.md
